;; config guide: https://github.com/jtroo/kanata/blob/main/docs/config.adoc
;; met == cmd in mac

;; (defalias
  ;; sft (fork lsft (multi lmet lsft tab) (or lmet lctl))
;; )

(defalias
  act (tap-hold-press 200 500 S-tab lsft)
  sft (switch
    ((or (input real lalt) (input real caps))) @act break
    () lsft break
  )
)

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold yes
  danger-enable-cmd yes
  macos-dev-names-include (
    "USB Keyboard"
  )
)

(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12
  grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab  q    w    e    r    t    y    u    i    o    p    [    ]    \
  caps a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft z    x    c    v    b    n    m    ,    .    /    rsft
  lctl lmet lalt             spc             ralt rmet  del rctl
)

(deflayer default
  caps   🔅   🔆   _    _    _    _    ◀◀   ▶⏸   ▶▶   🔇   🔉   🔊
  grv    1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab    q    w    e    r    t    y    u    i    o    p    [    ]    \
  @caps  a    s    d    f    g    h    j    k    l    ;    '    ret
  @sft  z    x    c    v    b    n    m    ,    .    /    rsft
  @lctl  lalt @lmet           spc          rmet ralt del rctl
)

(deflayer fn
  caps   f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12 
  grv    1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab    q    w    e    r    t    y    u    i    o    p    [    ]    \
  @caps  a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft  z    x    c    v    b    n    m    ,    .    /    rsft
  @lctl  lalt @lmet           spc          rmet ralt del @fn
)


(defoverrides
  (lmet h) (left)
  (lmet j) (down)
  (lmet k) (up)
  (lmet l) (right)
  (lmet ret) (lctrl ret) ;; mimic mac
  (lmet v) (lctrl v) ;; mimic mac
  (lmet c) (lctrl c) ;; mimic mac
  (lmet w) (lctrl w) ;; mimic mac
  (lmet q) (lctrl q) ;; mimic mac
  (lmet f) (lctrl f) ;; mimic mac
  (lmet r) (lctrl r) ;; mimic mac
)


(deflayer leader
;;  esc   f1    f2    f3    f4    f5    f6    f7    f8    f9    f10   f11   f12
    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  grv   1     2     3     4     5     6     7     8     9     0     -     =     bspc
    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  tab   q     w     e     r     t                  y     u     i     o     p     [     ]     \
    XX    XX    XX    XX    XX    @open_alacritty    XX    XX    XX    XX    XX    XX    XX    XX

;;  caps            a     s     d     f     g     h     j     k     l     ;     '     ret
    @layer_default  @aaa  XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  lsft  z               x     c               v     b              n     m     ,     .     /     rsft
    XX    @open_youtube   XX    @open_cursor    XX    @open_firefox  XX    XX    XX    XX    XX    XX

;;  lctl    lmet  lalt              spc              ralt  rmet  del   rctl
    @lctl   XX    XX                XX               XX    XX    XX    XX
)


(deflayer aaa
;;  esc   f1    f2    f3    f4    f5    f6    f7    f8    f9    f10   f11   f12
    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  grv   1     2     3     4     5     6     7     8     9     0     -     =     bspc
    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  tab   q     w     e     r     t     y     u     i     o     p     [     ]     \
    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  caps             a               s     d     f     g     h     j     k     l     ;     '     ret
    @layer_default   @open_gemini    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX    XX

;;  lsft  z    x     c                v     b   n     m     ,     .     /     rsft
    XX    XX   XX    @open_chatgpt    XX    XX  XX    XX    XX    XX    XX    XX

;;  lctl    lmet  lalt              spc              ralt  rmet  del   rctl
    @lctl   XX    XX                XX               XX    XX    XX    XX
)



(defalias
  caps  (tap-hold-press 200 500 esc lctl)
  lmet  (tap-hold-press 200 500 A-0 lmet) ;; A-0 is as leader key for zellij
  fn  (tap-hold-press 200 500 lctl (layer-while-held  fn))

  lctl  (tap-hold-press 200 500 (layer-switch leader) (multi lctl lmet lalt)) ;; A-9 is the leader for yabai/skhd


  aaa (layer-switch aaa)

  open_alacritty (multi
    (cmd bash -c "wmctrl -xa Alacritty || alacritty")
    (layer-switch default)
  )


  open_cursor (multi
    (cmd bash -c "wmctrl -xa Cursor || cursor")
    (layer-switch default)
  )

  open_firefox (multi
    (cmd bash -c "wmctrl -xa Firefox || firefox")
    (layer-switch default)
  )

  open_youtube (multi
    (cmd bash -c "wmctrl -xa Firefox || firefox")
    (cmd fish -c "mytab 'youtube.com'")
    (layer-switch default)
  )


  open_chatgpt (multi
    (cmd bash -c "wmctrl -xa Firefox || firefox")
    (cmd fish -c "mytab 'https://chatgpt.com'")
    (layer-switch default)
  )

  open_gemini (multi
    (cmd bash -c "wmctrl -xa Firefox || firefox")
    (cmd fish -c "mytab 'aistudio.google.com'")
    (layer-switch default)
  )

  layer_default (layer-switch default)
)
